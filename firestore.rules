rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;

      match /calls/{callId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /backups/{backupId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.memberIds);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.memberIds);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.memberIds);
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.memberIds
        || resource.data.senderId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.memberIds
      );
      allow update: if isAuthenticated() && (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.memberIds
      );
      allow delete: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid
        || request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.memberIds
      );
    }

    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /active_calls/{callId} {
      allow read, write: if isAuthenticated() && (
        request.auth.uid in resource.data.memberIds || request.auth.uid in request.resource.data.memberIds
      );
    }
  }
}
